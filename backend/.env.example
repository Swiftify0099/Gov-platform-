# ============================================
# EXAM PREP PLATFORM — ENVIRONMENT VARIABLES
# ============================================

# --- Application ---
ENVIRONMENT=development
APP_NAME=ExamPrepPlatform
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:19006

# --- Database ---
DATABASE_URL=postgresql+asyncpg://examuser:exampass@localhost:5432/examdb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_OTP_TTL=300
REDIS_SESSION_TTL=86400
REDIS_GPT_CACHE_TTL=86400

# --- JWT ---
JWT_SECRET_KEY=jwt-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET_KEY=jwt-refresh-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Local File Storage ---
LOCAL_STORAGE_ROOT=./data/uploads
PROFILE_PHOTO_DIR=./data/uploads/profile_photos
QUESTION_FILE_DIR=./data/uploads/question_files
VIOLATION_SCREENSHOT_DIR=./data/uploads/violation_screenshots
TEMP_DIR=./data/uploads/temp
MAX_UPLOAD_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
TEMP_FILE_RETENTION_HOURS=24

# --- OTP (Twilio) ---
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# --- OTP (MSG91 alternative) ---
# SMS_PROVIDER=msg91
# MSG91_AUTH_KEY=your_msg91_auth_key
# MSG91_TEMPLATE_ID=your_template_id
# MSG91_SENDER_ID=EXAMPP

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=500

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# --- PhonePe ---
PHONEPE_MERCHANT_ID=your_merchant_id
PHONEPE_SALT_KEY=your_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=[api-preprod.phonepe.com](https://api-preprod.phonepe.com/apis/pg-sandbox)

# --- Active Payment Gateway (toggled by Super Admin) ---
ACTIVE_PAYMENT_GATEWAY=razorpay

# --- Face Verification ---
FACE_MATCH_THRESHOLD=0.6
FACE_CHECK_INTERVAL_SECONDS=10
MAX_VIOLATIONS=3

# --- Default Admin Credentials (CHANGE IN PRODUCTION) ---
SUPER_ADMIN_PHONE=9000000000
SUPER_ADMIN_NAME=Super Admin
DEFAULT_INSTITUTE_ADMIN_PHONE=9000000001
DEFAULT_INSTITUTE_ADMIN_NAME=Institute Admin

# --- CORS ---
ALLOW_CREDENTIALS=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
